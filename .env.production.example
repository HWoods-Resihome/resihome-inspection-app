# ──────────────────────────────────────────────────────────────────────────
# ResiWalk — PRODUCTION environment variables (set these in Vercel → Project →
# Settings → Environment Variables, "Production" scope). Do NOT commit real
# values; this file is a template only.
# ──────────────────────────────────────────────────────────────────────────

# ── HubSpot (required) ──
HUBSPOT_TOKEN=pat-na1-...                 # Production private-app token ("ResiWlk")
HUBSPOT_PORTAL_ID=22536354                # Production portal id

# Object type IDs — copy the values printed by `clone_to_prod.py import --live`
# (format like 2-12345678). These tell the app which custom objects to use.
HUBSPOT_INSPECTION_TYPE_ID=2-...
HUBSPOT_INSPECTION_QUESTION_TYPE_ID=2-...
HUBSPOT_INSPECTION_ANSWER_TYPE_ID=2-...
HUBSPOT_PROPERTY_TYPE_ID=2-...
# Recommended (skips a startup schema lookup; from the same import output):
HUBSPOT_RATE_CARD_LINE_ITEM_TYPE_ID=2-...
HUBSPOT_REGION_RATE_TYPE_ID=2-...

# ── Auth / session (required) ──
SESSION_SECRET=                           # long random string (e.g. `openssl rand -hex 32`)

# ── AI (required for AI review; recommended for voice/transcription) ──
ANTHROPIC_API_KEY=sk-ant-...              # AI scope review
VOYAGE_API_KEY=                           # voice catalog matching (optional)
OPENAI_API_KEY=                           # voice transcription (optional)

# ── Email (optional — completion emails) ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://<your-prod-domain>/api/auth/gmail/callback

# ── Push notifications (optional — approval alerts in the installed PWA) ──
# Generate a keypair once with:  npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the browser (NEXT_PUBLIC_*); keep the PRIVATE
# key server-only. Without these, push is inert (the app runs fine).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=             # public VAPID key (browser-safe)
VAPID_PRIVATE_KEY=                        # private VAPID key (server only)
VAPID_SUBJECT=mailto:hwoods@resihome.com  # contact for push services (mailto: or https URL)
# Native (Capacitor) push via Firebase Cloud Messaging. Paste the FULL service
# account JSON (Firebase → Project settings → Service accounts → Generate key).
# Inert until set; web push works without it.
FCM_SERVICE_ACCOUNT_JSON=                 # {"type":"service_account","project_id":"...",...}

# ── Microsoft / Outlook sign-in (optional — lets 1099 agents sign in with an
#    Outlook/Microsoft account instead of Google). From an Azure / Microsoft
#    Entra app registration. Redirect URI must be registered there too. Use the
#    secret VALUE (not the Secret ID GUID). Inert until set. ──
MS_CLIENT_ID=                              # Application (client) ID
MS_CLIENT_SECRET=                          # client secret VALUE (shown once at creation)
MS_REDIRECT_URI=https://resiwalk.com/api/auth/microsoft/callback
MS_TENANT=common                           # "common" = any org + personal Microsoft accounts

# ── Feature flags (optional) ──
FINALIZE_LOCK_PROPERTY=finalize_in_progress   # durable finalize lock (default name)
ERROR_WEBHOOK_URL=                            # pipe client errors to Slack/Sentry
# AI self-improvement: learned catalog-match nudges are ON by default. Set to 0
# as a kill switch if matching ever regresses. (No effect until the daily cron
# has built a model from captured feedback; deltas clamped to ±0.05.)
AI_LEARNING_ENABLED=1
