{
  "functions": {
    "pages/api/submit.ts": {
      "maxDuration": 10
    },
    "pages/api/pdf.ts": {
      "maxDuration": 60
    },
    "pages/api/upload.ts": {
      "maxDuration": 10
    },
    "pages/api/inspections/[id]/finalize.ts": {
      "maxDuration": 60
    },
    "pages/api/inspections/[id]/qc-finalize.ts": {
      "maxDuration": 60
    },
    "pages/api/cron/sftp-watch.ts": {
      "maxDuration": 60
    },
    "pages/api/cron/blob-cleanup.ts": {
      "maxDuration": 60
    },
    "pages/api/cron/auto-cancel-stale.ts": {
      "maxDuration": 60
    },
    "pages/api/insights/rebuild.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sftp-watch",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/blob-cleanup",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/auto-cancel-stale",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/insights/rebuild",
      "schedule": "*/30 * * * *"
    }
  ]
}
