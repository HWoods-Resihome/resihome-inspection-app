# ResiWALK iOS — TestFlight build lane.
#
# Auth + signing use ONLY an App Store Connect API key (no Apple-ID password, no
# fastlane match repo, no committed certificates). Xcode manages signing
# automatically via `-allowProvisioningUpdates`, creating/fetching the
# distribution cert + provisioning profile on the runner using the API key.
#
# Required ENV (set as GitHub Secrets, passed through by the workflow):
#   ASC_KEY_ID      App Store Connect API Key ID
#   ASC_ISSUER_ID   App Store Connect API issuer ID
#   ASC_KEY_P8      the .p8 private key, base64-encoded
#   APPLE_TEAM_ID   10-char Apple Developer Team ID
#   BUILD_NUMBER    unique, monotonic build number (the workflow passes github.run_number)

default_platform(:ios)

platform :ios do
  desc "Build the ResiWALK shell and upload to TestFlight"
  lane :beta do
    # Creates a temporary CI keychain (so automatic signing has somewhere to put
    # the fetched certificate) and tunes other CI-only defaults.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
      in_house: false,
    )

    team_id   = ENV.fetch("APPLE_TEAM_ID")
    build_num = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s

    # --- Signing (explicit, manual) ---
    # Automatic/cloud signing archived as "Development" (needs registered devices)
    # and forcing the identity globally also broke the Pods targets. Instead:
    #   1. create/fetch an Apple Distribution certificate (private key lands in the
    #      temp CI keychain that setup_ci made default),
    #   2. create/fetch an App Store provisioning profile (needs NO devices),
    # both via the API key, then apply manual distribution signing to the App
    # target ONLY — Pods keep their own (unsigned) settings.
    #
    # NOTE: on an ephemeral runner this creates a NEW distribution certificate each
    # run; Apple caps those (~2–3). For ongoing use switch to `match` (shared,
    # reused cert) — see mobile/BUILD_RUNBOOK.md follow-up.
    # setup_ci's lane-context KEYCHAIN_PATH is "~/Library/Keychains/
    # fastlane_tmp_keychain" (no suffix), but the real file is "...-db", so
    # get_certificates' existence check fails on it. Point at the actual file.
    ci_keychain = File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db")
    get_certificates(
      api_key: api_key,
      # Import into the temp keychain setup_ci created (password is empty),
      # otherwise cert lands in login.keychain and can't be configured for
      # signing ("no local code signing identities found").
      keychain_path: ci_keychain,
      keychain_password: "",
    )
    profile_name = get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.resihome.resiwalk",
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"],
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_num}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          "com.resihome.resiwalk" => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      # The app's numeric App Store Connect ID (not a secret) — lets fastlane
      # resolve the app directly instead of searching by bundle id.
      apple_id: "6780963726",
      # Don't block the runner waiting for Apple's async processing — the build
      # shows up in TestFlight a few minutes later.
      skip_waiting_for_build_processing: true,
    )
  end
end
