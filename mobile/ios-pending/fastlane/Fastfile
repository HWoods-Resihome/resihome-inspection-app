# ResiWALK iOS — TestFlight build lane.
#
# Auth + signing use ONLY an App Store Connect API key (no Apple-ID password, no
# fastlane match repo, no committed certificates). Xcode manages signing
# automatically via `-allowProvisioningUpdates`, creating/fetching the
# distribution cert + provisioning profile on the runner using the API key.
#
# Required ENV (set as GitHub Secrets, passed through by the workflow):
#   ASC_KEY_ID      App Store Connect API Key ID
#   ASC_ISSUER_ID   App Store Connect API issuer ID
#   ASC_KEY_P8      the .p8 private key, base64-encoded
#   APPLE_TEAM_ID   10-char Apple Developer Team ID
#   BUILD_NUMBER    unique, monotonic build number (the workflow passes github.run_number)

default_platform(:ios)

platform :ios do
  desc "Build the ResiWALK shell and upload to TestFlight"
  lane :beta do
    # Creates a temporary CI keychain (so automatic signing has somewhere to put
    # the fetched certificate) and tunes other CI-only defaults.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
      in_house: false,
    )

    team_id   = ENV.fetch("APPLE_TEAM_ID")
    build_num = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s

    # gym/build_app has NO `api_key` option, so we hand the App Store Connect API
    # key straight to xcodebuild. Write the (base64) .p8 to disk and pass its path
    # plus the key/issuer IDs to both the archive and export steps — that's what
    # `-allowProvisioningUpdates` needs to create the distribution cert + profile
    # via cloud signing (otherwise xcodebuild reports "No Accounts").
    require "base64"
    require "tmpdir"
    asc_key_path = File.join(Dir.tmpdir, "fastlane_asc_api_key.p8")
    File.write(asc_key_path, Base64.decode64(ENV.fetch("ASC_KEY_P8")))
    auth_args = "-allowProvisioningUpdates " \
      "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')} " \
      "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')} " \
      "-authenticationKeyPath #{asc_key_path}"

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      # Cloud signing via the API key for both archive and export. Force the
      # "Apple Distribution" identity so the ARCHIVE provisions an App Store
      # distribution profile (needs no registered devices) instead of a
      # Development profile — Capacitor's project otherwise defaults to dev
      # signing, which fails on CI with "no devices ... iOS App Development".
      xcargs: "#{auth_args} DEVELOPMENT_TEAM=#{team_id} CODE_SIGN_IDENTITY=\"Apple Distribution\" CURRENT_PROJECT_VERSION=#{build_num}",
      export_xcargs: auth_args,
      export_options: {
        signingStyle: "automatic",
        teamID: team_id,
      },
    )

    upload_to_testflight(
      api_key: api_key,
      # The app's numeric App Store Connect ID (not a secret) — lets fastlane
      # resolve the app directly instead of searching by bundle id.
      apple_id: "6780963726",
      # Don't block the runner waiting for Apple's async processing — the build
      # shows up in TestFlight a few minutes later.
      skip_waiting_for_build_processing: true,
    )
  end
end
