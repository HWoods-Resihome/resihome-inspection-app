# ResiWALK iOS — TestFlight build lane.
#
# Auth uses an App Store Connect API key. Code signing uses fastlane `match`:
# ONE Apple Distribution certificate + App Store provisioning profile are created
# once, stored ENCRYPTED in this repo on the `ios-signing-certs` branch, and
# REUSED by every build (no per-run certificate creation, no Apple cert-cap).
#
# Required ENV (set as GitHub Secrets, passed through by the workflow):
#   ASC_KEY_ID      App Store Connect API Key ID
#   ASC_ISSUER_ID   App Store Connect API issuer ID
#   ASC_KEY_P8      the .p8 private key, base64-encoded
#   APPLE_TEAM_ID   10-char Apple Developer Team ID
#   MATCH_PASSWORD  passphrase that encrypts the match cert/profile storage
#   BUILD_NUMBER    unique, monotonic build number (workflow passes github.run_number)
#
# One-time bootstrap ENV (set ONLY for the first match run, then removed):
#   RESET_DIST_CERTS=1  revoke existing distribution certs so match can mint a
#                       fresh, storable one (needed when the account is at the
#                       distribution-cert cap with no locally-usable key).

APP_ID = "com.resihome.resiwalk".freeze
MATCH_GIT_URL = "https://github.com/HWoods-Resihome/resihome-inspection-app.git".freeze
MATCH_GIT_BRANCH = "ios-signing-certs".freeze

default_platform(:ios)

platform :ios do
  desc "Build the ResiWALK shell and upload to TestFlight"
  lane :beta do
    # Temporary CI keychain (match installs the cert here; setup_ci makes it the
    # default and exports MATCH_KEYCHAIN_NAME/PASSWORD that match reads).
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
      in_house: false,
    )

    team_id   = ENV.fetch("APPLE_TEAM_ID")
    build_num = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s

    # One-time cleanup (guarded): earlier "create a cert per run" builds left
    # orphaned distribution certs with no locally-usable private key, hitting
    # Apple's cap so match can't mint a new one. Revoke distribution certs via
    # the API key to free slots. Runs ONLY when RESET_DIST_CERTS=1 so it never
    # nukes the match-managed cert on normal builds.
    if ENV["RESET_DIST_CERTS"] == "1"
      require "base64"
      Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key: Base64.decode64(ENV.fetch("ASC_KEY_P8")),
      )
      dist_types = %w[DISTRIBUTION IOS_DISTRIBUTION]
      Spaceship::ConnectAPI::Certificate.all.each do |cert|
        next unless dist_types.include?(cert.certificate_type)
        UI.important("Revoking distribution certificate #{cert.id} (#{cert.display_name})")
        if cert.respond_to?(:delete!)
          cert.delete!
        else
          Spaceship::ConnectAPI.delete_certificate(certificate_id: cert.id)
        end
      end
    end

    # Fetch (or, on first run, create + store) the shared distribution cert and
    # App Store profile. readonly:false lets the first run populate the storage
    # branch; later runs just download and import.
    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: APP_ID,
      git_url: MATCH_GIT_URL,
      git_branch: MATCH_GIT_BRANCH,
      readonly: false,
    )

    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]&.fetch(APP_ID, nil) ||
                   ENV["sigh_#{APP_ID}_appstore_profile-name"]

    # Manual distribution signing on the App target ONLY (Pods keep their own
    # settings, otherwise the storyboard/Pods targets fail to sign).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"],
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_num}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          APP_ID => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      # The app's numeric App Store Connect ID (not a secret) — lets fastlane
      # resolve the app directly instead of searching by bundle id.
      apple_id: "6780963726",
      # Don't block the runner waiting for Apple's async processing — the build
      # shows up in TestFlight a few minutes later.
      skip_waiting_for_build_processing: true,
    )
  end
end
